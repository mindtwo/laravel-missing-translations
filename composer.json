{
    "name": "mindtwo/laravel-missing-translations",
    "description": "Browser-based viewer and database collector for missing Laravel translation keys.",
    "keywords": [
        "laravel",
        "translations",
        "localization",
        "i18n",
        "missing-translations"
    ],
    "homepage": "https://github.com/mindtwo/missing-translations",
    "license": "MIT",
    "authors": [
        {
            "name": "mindtwo GmbH",
            "email": "info@mindtwo.de",
            "homepage": "https://www.mindtwo.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2||^8.3||^8.4",
        "laravel/framework": "^10.0||^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9||^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^7.10.0||^8.1.1",
        "orchestra/testbench": "^8.22.0||^9.0.0||^10.0.0||^11.0.0",
        "pestphp/pest": "^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^3.0||^4.0",
        "phpstan/extension-installer": "^1.3||^2.0",
        "phpstan/phpstan-deprecation-rules": "^1.1||^2.0",
        "phpstan/phpstan-phpunit": "^1.3||^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "mindtwo\\LaravelMissingTranslations\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "mindtwo\\LaravelMissingTranslations\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "baseline": "vendor/bin/phpstan analyse --generate-baseline",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "test": "vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "mindtwo\\LaravelMissingTranslations\\MissingTranslationsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}
